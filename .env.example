# ── Required ──────────────────────────────────────────────────────────────────
# Set a strong password. This is used by both Postgres and the app.
POSTGRES_PASSWORD=change-me-please

# ── Optional ──────────────────────────────────────────────────────────────────
# Postgres database name and user (defaults shown)
# POSTGRES_DB=dogear
# POSTGRES_USER=dogear

# Port DogEar listens on (default: 6300)
# DOGEAR_PORT=6300

# ── pgAdmin (optional) ────────────────────────────────────────────────────────
# Uncomment the pgadmin service in docker-compose.yml to enable.
# PGADMIN_EMAIL=admin@dogear.local
# PGADMIN_PASSWORD=change-me-please
# DOGEAR_PGADMIN_PORT=5050

# ── Local development only ────────────────────────────────────────────────────
# In Docker, DATABASE_URL is set automatically from the variables above.
# Only needed when running `npm run dev` outside Docker.
# DATABASE_URL=postgresql://dogear:change-me-please@localhost:5432/dogear
