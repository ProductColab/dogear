# ── App ──────────────────────────────────────────────────────────────────────
# Postgres connection string (auto-set in Docker — only needed for local dev)
DATABASE_URL=postgresql://dogear:dogear@localhost:5432/dogear

# ── HTTPS ────────────────────────────────────────────────────────────────────
# Hostname for Caddy's TLS certificate.
# Leave unset for self-signed (local IP). Set to Tailscale hostname or domain
# for a trusted cert with no installs required.
# DOGEAR_HOST=my-server.tail1234.ts.net
# DOGEAR_HOST=library.yourdomain.com

# ── Ports ────────────────────────────────────────────────────────────────────
# Change these if you have port conflicts with other services.
# Defaults: HTTP=80, HTTPS=443, pgAdmin=5050
# DOGEAR_HTTP_PORT=80
# DOGEAR_HTTPS_PORT=443
# DOGEAR_PGADMIN_PORT=5050

# Postgres is not exposed to the host by default (internal Docker network only).
# Uncomment the ports section in docker-compose.yml and set this if you need
# direct DB access from tools like TablePlus or pgAdmin on your machine.
# DOGEAR_DB_PORT=54320
